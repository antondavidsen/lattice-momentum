# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=momentum
POSTGRES_PASSWORD=momentum
POSTGRES_DB=momentum_ai

# Constructed by docker-compose; override only if running outside Docker
DATABASE_URL=postgres://momentum:momentum@localhost:5432/momentum_ai?sslmode=disable

# ── Market Data Provider ───────────────────────────────────────────────────────
# Choose one: polygon | twelvedata
MARKET_DATA_PROVIDER=polygon

POLYGON_API_KEY=your_polygon_api_key_here
TWELVEDATA_API_KEY=your_twelvedata_api_key_here

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Eval provider (Step 9): "anthropic" (default) | "openai" | "gemini"
LLM_PROVIDER=anthropic
LLM_EVAL_ENABLED=true
# LLM_MODEL=                      # empty → provider default

# Commercial report provider (Step 12): defaults to "openai"
COMMERCIAL_LLM_PROVIDER=openai
# COMMERCIAL_LLM_MODEL=           # empty → provider default

COMMERCIAL_REPORT_ENABLED=true

ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Enrichment ────────────────────────────────────────────────────────────────
ENRICHMENT_ENABLED=true
MARKET_DATA_WORKER_COUNT=2
FINNHUB_API_KEY=your_finnhub_api_key_here

# ── Pre-Market ────────────────────────────────────────────────────────────────
PREMARKET_ENABLED=false
PREMARKET_CRON_SCHEDULE=30 11 * * 1-5
PREMARKET_LLM_CATALYST_ENABLED=true

# ── Prompt Memory & RAG ───────────────────────────────────────────────────────
# Requires OPENAI_API_KEY for embeddings (text-embedding-3-small).
PROMPT_MEMORY_ENABLED=false        # pgvector memory storage
EMBEDDING_BACKEND=noop             # "openai" to activate
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_ENDPOINT_URL=

RAG_ENABLED=false                  # RAG analogue injection into LLM prompts
RAG_TOP_K=3
RAG_MAX_AGE_DAYS=365

# ── XGBoost/LightGBM Model Refit (monthly) ──────────────────────────────────
# Requires Python sidecar in monthly-learning container + API key for data export.
PREMONITION_ENABLED=false
PREMONITION_BACKEND=xgboost
PREMONITION_MIN_AUC=0.65
PREMONITION_TMP_DIR=/tmp/premonition

# ── TradingView Collector ─────────────────────────────────────────────────────
# Set empty to skip Step 1 in local dev when tv-collector is not running
TV_COLLECTOR_URL=http://localhos:t:8001

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Mon–Fri at 21:00 UTC (17:00 ET = 1 h after US market close at 16:00 ET / 20:00 UTC)
# DO NOT use 18:00 UTC — that is 14:00 ET, two hours BEFORE market close.
CRON_SCHEDULE=0 21 * * 1-5

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
APP_ENV=development

# ── API Authentication ────────────────────────────────────────────────────────
# Shared secret for all /api/v1/* endpoints. Generate with: openssl rand -hex 32
# Same value must be set as VITE_API_KEY when building the frontend.
API_KEY=
VITE_API_KEY=