# ── Backend ───────────────────────────────────────────────────────────────────
# Base URL of the Go API service.
# In Docker Compose this is the service name: http://api:8080
BACKEND_API_URL=http://api:8080

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Time of day to run the collection, HH:MM in 24-hour format.
COLLECT_TIME=18:00


# Optional: full 5-field cron expression. Overrides COLLECT_TIME when set.
# Use for testing (e.g. every 2 min) without changing COLLECT_TIME.
# COLLECT_CRON=*/2 * * * *

# IANA timezone used for scheduling.
TIMEZONE=America/New_York

# ── TradingView ───────────────────────────────────────────────────────────────
# Browser engine for TradingView cookie extraction (local dev only).
# Inside Docker this is ignored when TV_COOKIES_FILE is set.
TV_BROWSER=chromium

# Path INSIDE the container to a Netscape-format cookies.txt file.
# Used for live (real-time) TradingView data inside Docker.
# Export from your browser with the "cookies.txt" extension, then set:
#   TV_COOKIES_PATH=/path/on/host/tradingview_cookies.txt  (in root .env)
#   TV_COOKIES_FILE=/run/secrets/tradingview_cookies.txt   (inside container)
TV_COOKIES_FILE=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Data ──────────────────────────────────────────────────────────────────────
# Directory where raw screener CSVs are written before upload.
RAW_DATA_DIR=./data/raw

